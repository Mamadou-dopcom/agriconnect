# ============================
# AGRICONNECT — CONFIGURATION
# ============================

# Database PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/agriconnect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string-here-use-openssl-rand-base64-32"

# Wave API Senegal
WAVE_API_KEY="your_wave_api_key_here"
WAVE_API_URL="https://api.wave.com/v1"
WAVE_WEBHOOK_SECRET="your_wave_webhook_secret_here"

# Orange Money
ORANGE_MONEY_API_KEY="your_orange_money_api_key_here"
ORANGE_MONEY_API_URL="https://api.orange.com"
ORANGE_WEBHOOK_SECRET="your_orange_webhook_secret_here"

# Commerce configuration
DEFAULT_DELIVERY_FEE="700"
MIN_DELIVERY_FEE="0"
MAX_DELIVERY_FEE="50000"
PLATFORM_COMMISSION_PERCENT="10"
PENDING_PAYMENT_EXPIRY_MINUTES="15"

# Cron protection (optional but recommended)
CRON_SECRET="your_cron_secret_here"

# Environment
NODE_ENV="development"
