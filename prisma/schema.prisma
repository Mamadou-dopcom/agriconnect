// ============================================
// AGRICONNECT — SCHÉMA PRISMA
// Base de données: PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// UTILISATEURS
// ============================================
model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  role          Role      @default(BUYER)
  avatarUrl     String?   @map("avatar_url")
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  region        String?
  city          String?
  address       String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  farmerProfile   FarmerProfile?
  products        Product[]
  buyerOrders     Order[]        @relation("BuyerOrders")
  farmerOrders    Order[]        @relation("FarmerOrders")
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  notifications   Notification[]

  @@map("users")
}

enum Role {
  FARMER
  BUYER
  ADMIN
}

// ============================================
// PROFIL AGRICULTEUR
// ============================================
model FarmerProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  farmName           String?  @map("farm_name")
  farmDescription    String?  @map("farm_description")
  farmSizeHectares   Float?   @map("farm_size_hectares")
  yearsExperience    Int      @default(0) @map("years_experience")
  specialties        String[]
  deliveryRadiusKm   Int      @default(50) @map("delivery_radius_km")
  acceptsDelivery    Boolean  @default(true) @map("accepts_delivery")
  bankAccountWave    String?  @map("bank_account_wave")
  bankAccountOrange  String?  @map("bank_account_orange")
  totalSales         Int      @default(0) @map("total_sales")
  rating             Float    @default(0)
  ratingCount        Int      @default(0) @map("rating_count")
  isCertified        Boolean  @default(false) @map("is_certified")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("farmer_profiles")
}

// ============================================
// CATÉGORIES
// ============================================
model Category {
  id          String    @id @default(uuid())
  name        String
  nameWolof   String?   @map("name_wolof")
  emoji       String?
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  products    Product[]

  @@map("categories")
}

// ============================================
// PRODUITS
// ============================================
model Product {
  id                String   @id @default(uuid())
  farmerId          String   @map("farmer_id")
  categoryId        String?  @map("category_id")
  name              String
  nameWolof         String?  @map("name_wolof")
  description       String?
  pricePerUnit      Float    @map("price_per_unit")
  unit              String   @default("kg")
  quantityAvailable Float    @default(0) @map("quantity_available")
  minOrderQuantity  Float    @default(1) @map("min_order_quantity")
  images            String[]
  harvestDate       DateTime? @map("harvest_date")
  expiryDate        DateTime? @map("expiry_date")
  isOrganic         Boolean  @default(false) @map("is_organic")
  isAvailable       Boolean  @default(true) @map("is_available")
  viewsCount        Int      @default(0) @map("views_count")
  ordersCount       Int      @default(0) @map("orders_count")
  region            String?
  city              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  farmer     User       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  category   Category?  @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

// ============================================
// COMMANDES
// ============================================
model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique @map("order_number")
  buyerId            String        @map("buyer_id")
  farmerId           String        @map("farmer_id")
  status             OrderStatus   @default(PENDING)
  deliveryType       DeliveryType  @default(DELIVERY) @map("delivery_type")
  deliveryAddress    String?       @map("delivery_address")
  deliveryDate       DateTime?     @map("delivery_date")
  subtotal           Float
  deliveryFee        Float         @default(0) @map("delivery_fee")
  platformCommission Float         @default(0) @map("platform_commission")
  totalAmount        Float         @map("total_amount")
  paymentMethod      PaymentMethod? @map("payment_method")
  paymentStatus      PaymentStatus @default(PENDING) @map("payment_status")
  paymentReference   String?       @map("payment_reference")
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  buyer    User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  farmer   User        @relation("FarmerOrders", fields: [farmerId], references: [id])
  items    OrderItem[]
  review   Review?
  payment  Payment?

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ============================================
// ARTICLES DE COMMANDE
// ============================================
model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  quantity    Float
  unit        String
  unitPrice   Float   @map("unit_price")
  totalPrice  Float   @map("total_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================
// AVIS
// ============================================
model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique @map("order_id")
  reviewerId String   @map("reviewer_id")
  reviewedId String   @map("reviewed_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id])
  reviewer User  @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewed User  @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  @@map("reviews")
}

// ============================================
// PAIEMENTS
// ============================================
model Payment {
  id               String        @id @default(uuid())
  orderId          String        @unique @map("order_id")
  amount           Float
  currency         String        @default("XOF")
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  providerReference String?      @map("provider_reference")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ============================================
// NOTIFICATIONS
// ============================================
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
